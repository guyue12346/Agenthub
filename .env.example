DATABASE_URL="postgresql://agenthub:agenthub@localhost:5432/agenthub?schema=public"
PORT=3100
WEB_ORIGIN="http://127.0.0.1:5173,http://localhost:5173"

# RunAPI OpenAI-compatible endpoint.
AGENTHUB_LLM_PROVIDER="runapi"
AGENTHUB_LLM_BASE_URL="https://runapi.co/v1"
AGENTHUB_LLM_API_KEY="replace-with-your-runapi-key"
AGENTHUB_LLM_MODEL="gpt-5.5"
AGENTHUB_LLM_REASONING_EFFORT="high"
AGENTHUB_LLM_WIRE_API="responses"

AGENTHUB_CODE_RUNNER_MODE="docker"
AGENTHUB_ALLOW_UNSAFE_LOCAL_RUNNER="false"
AGENTHUB_CODE_RUNNER_IMAGE="agenthub-code-runner:latest"
AGENTHUB_CODEX_MODEL="gpt-5.5"
AGENTHUB_CODEX_REASONING_EFFORT="high"
AGENTHUB_OPENCODE_MODEL="runapi_openai/gpt-5.5"
AGENTHUB_OPENCODE_REASONING_EFFORT="high"
